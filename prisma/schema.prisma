// SMS LocalBlast — foundation schema (organizations, users, sessions, audit).
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserGlobalStatus {
  ACTIVE
  SUSPENDED
  INVITED
}

enum OrganizationStatus {
  ACTIVE
  SUSPENDED
}

enum MembershipStatus {
  ACTIVE
  SUSPENDED
}

enum RoleScope {
  SYSTEM
  ORGANIZATION
}

enum DevicePlatform {
  ANDROID
  IOS
}

enum DeviceStatus {
  PENDING
  ONLINE
  OFFLINE
  SUSPENDED
  DISCONNECTED
}

enum DeviceHealthStatus {
  HEALTHY
  WARNING
  CRITICAL
  UNKNOWN
}

enum ContactStatus {
  ACTIVE
  BLOCKED
  OPTED_OUT
  ARCHIVED
}

enum ContactSource {
  MANUAL
  CSV_IMPORT
  XLSX_IMPORT
  API
  EXCEL_ADDIN
}

enum ContactCustomFieldValueType {
  TEXT
  NUMBER
  BOOLEAN
  DATE
  JSON
}

enum TemplateChannelType {
  SMS
  MMS
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  PROCESSING
  PAUSED
  COMPLETED
  CANCELLED
  FAILED
}

enum CampaignRecipientStatus {
  PENDING
  SKIPPED
  READY
  QUEUED
  PROCESSING
  SENT
  DELIVERED
  FAILED
  CANCELLED
}

enum CampaignRecipientSourceType {
  DIRECT_CONTACT
  CONTACT_LIST
  IMPORT_SNAPSHOT
}

enum MessageChannelType {
  SMS
  MMS
}

enum MessageStatus {
  PENDING
  READY
  QUEUED
  DISPATCHING
  DISPATCHED
  SENT
  DELIVERED
  FAILED
  SKIPPED
  CANCELLED
}

enum MessageDirection {
  OUTBOUND
  INBOUND
}

enum BillingProvider {
  STRIPE
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  UNPAID
  CANCELLED
  INCOMPLETE
  INCOMPLETE_EXPIRED
  PAUSED
}

enum PlanInterval {
  MONTH
  YEAR
}

enum EntitlementValueType {
  BOOLEAN
  NUMBER
  STRING
}

enum AuditAction {
  AUTH_REGISTER
  AUTH_LOGIN
  AUTH_REFRESH
  AUTH_LOGOUT
  AUTH_LOGOUT_ALL
  SESSION_REVOKED
  DEVICE_CREATED
  DEVICE_UPDATED
  DEVICE_DELETED
  DEVICE_PRIMARY_SET
  DEVICE_QUOTA_UPDATED
  DEVICE_HEARTBEAT_RECEIVED
  CONTACT_CREATED
  CONTACT_UPDATED
  CONTACT_DELETED
  CONTACT_OPTED_OUT
  CONTACT_BLOCKED
  CONTACT_UNBLOCKED
  CONTACT_LIST_CREATED
  CONTACT_LIST_UPDATED
  CONTACT_LIST_DELETED
  CONTACT_LIST_MEMBERS_ADDED
  CONTACT_LIST_MEMBER_REMOVED
  CONTACTS_IMPORT_PREVIEWED
  CONTACTS_IMPORT_CONFIRMED
  TEMPLATE_CREATED
  TEMPLATE_UPDATED
  TEMPLATE_DELETED
  TEMPLATE_VALIDATED
  TEMPLATE_PREVIEW_RENDERED
  CAMPAIGN_CREATED
  CAMPAIGN_UPDATED
  CAMPAIGN_DELETED
  CAMPAIGN_PREVIEWED
  CAMPAIGN_SCHEDULED
  CAMPAIGN_STARTED
  CAMPAIGN_PAUSED
  CAMPAIGN_CANCELLED
  CAMPAIGN_RECIPIENTS_PREPARED
  MESSAGES_GENERATED_FOR_CAMPAIGN
  MESSAGE_QUEUED
  MESSAGE_RETRY_SCHEDULED
  MESSAGE_CANCELLED
  MESSAGE_FAILED
  MESSAGE_DISPATCHED
  DEVICE_GATEWAY_AUTHENTICATED
  MESSAGE_CLAIMED_BY_DEVICE
  MESSAGE_SENT_REPORTED
  MESSAGE_DELIVERED_REPORTED
  MESSAGE_FAILED_REPORTED
  CAMPAIGN_FINALIZED
  OPERATIONS_VIEWED
  BILLING_CHECKOUT_SESSION_CREATED
  BILLING_PORTAL_SESSION_CREATED
  BILLING_SUBSCRIPTION_ACTIVATED
  BILLING_SUBSCRIPTION_UPDATED
  BILLING_SUBSCRIPTION_CANCELLED
  BILLING_PAYMENT_FAILED
  BILLING_QUOTA_LIMIT_REACHED
  BILLING_ENTITLEMENT_DENIED
}

model Organization {
  id        String              @id @default(cuid())
  name      String
  slug      String              @unique
  status    OrganizationStatus  @default(ACTIVE)
  deletedAt DateTime?
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  memberships Membership[]      @relation("OrganizationMemberships")
  sessions    Session[]         @relation("OrganizationSessions")
  devices Device[]             @relation("OrganizationDevices")
  deviceHeartbeats DeviceHeartbeat[] @relation("OrganizationDeviceHeartbeats")
  contacts Contact[]            @relation("OrganizationContacts")
  contactLists ContactList[]    @relation("OrganizationContactLists")
  contactListMemberships ContactListMembership[] @relation("OrganizationContactListMemberships")
  contactCustomFieldValues ContactCustomFieldValue[] @relation("OrganizationContactCustomFieldValues")
  templates             Template[] @relation("OrganizationTemplates")
  campaigns             Campaign[] @relation("OrganizationCampaigns")
  campaignRecipients    CampaignRecipient[] @relation("OrganizationCampaignRecipients")
  outboundMessages      OutboundMessage[] @relation("OrganizationOutboundMessages")
  messageStatusEvents   MessageStatusEvent[] @relation("OrganizationMessageStatusEvents")
  gatewayEventReceipts  MessageGatewayEventReceipt[] @relation("OrganizationGatewayEventReceipts")
  billingCustomers      BillingCustomer[]
  subscriptions         OrganizationSubscription[]
  usageCounters         UsageCounter[]
  billingEventLogs      BillingEventLog[]
  auditLogs   AuditLog[]
}

model User {
  id              String            @id @default(cuid())
  email           String            @unique
  passwordHash   String
  firstName      String
  lastName       String
  globalStatus   UserGlobalStatus  @default(ACTIVE)
  emailVerifiedAt DateTime?
  lastLoginAt     DateTime?
  deletedAt       DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  memberships Membership[]         @relation("UserMemberships")
  sessions    Session[]           @relation("UserSessions")
  auditLogs   AuditLog[]         @relation("AuditActor")
  createdDevices Device[]       @relation("UserCreatedDevices")
  createdContacts Contact[]     @relation("UserCreatedContacts")
  createdContactLists ContactList[] @relation("UserCreatedContactLists")
  createdTemplates    Template[]    @relation("UserCreatedTemplates")
  createdCampaigns   Campaign[]     @relation("UserCreatedCampaigns")

  invitedMemberships Membership[] @relation("InvitedByMemberships")
}

model Role {
  id           String           @id @default(cuid())
  name         String
  code         String           @unique
  description  String?
  scope         RoleScope        @default(ORGANIZATION)
  isSystemRole Boolean          @default(false)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  memberships    Membership[] @relation("RoleMemberships")
  rolePermissions RolePermission[] @relation("RoleRolePermissions")
}

model Permission {
  id          String           @id @default(cuid())
  code        String           @unique
  description String?
  createdAt   DateTime         @default(now())

  rolePermissions RolePermission[] @relation("PermissionRolePermissions")
}

model RolePermission {
  roleId       String
  permissionId String
  createdAt    DateTime @default(now())

  role       Role       @relation("RoleRolePermissions", fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation("PermissionRolePermissions", fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([permissionId])
}

model Membership {
  id              String            @id @default(cuid())
  userId          String
  organizationId  String
  roleId          String
  status          MembershipStatus @default(ACTIVE)
  joinedAt        DateTime          @default(now())
  invitedByUserId String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  organization Organization @relation("OrganizationMemberships", fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation("UserMemberships", fields: [userId], references: [id], onDelete: Cascade)
  role         Role         @relation("RoleMemberships", fields: [roleId], references: [id], onDelete: Restrict)
  invitedBy    User?        @relation("InvitedByMemberships", fields: [invitedByUserId], references: [id], onDelete: SetNull)

  @@unique([userId, organizationId])
  @@index([userId])
  @@index([organizationId])
  @@index([roleId])
}

model Session {
  id                 String   @id @default(cuid())
  userId             String
  organizationId     String?
  refreshTokenHash  String
  userAgent          String?
  ipAddress          String?
  deviceFingerprint  String?
  isRevoked          Boolean  @default(false)
  revokedAt          DateTime?
  expiresAt         DateTime
  lastUsedAt        DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user         User          @relation("UserSessions", fields: [userId], references: [id], onDelete: Cascade)
  organization Organization? @relation("OrganizationSessions", fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([organizationId])
  @@index([isRevoked])
  @@index([expiresAt])
  @@index([lastUsedAt])
}

model Device {
  id                 String            @id @default(cuid())
  organizationId     String
  createdByUserId    String?
  name               String
  platform           DevicePlatform
  appVersion        String?
  osVersion         String?
  deviceModel       String?
  deviceIdentifier  String           @unique
  pushToken         String?
  phoneNumber       String?
  simLabel          String?
  status             DeviceStatus    @default(PENDING)
  healthStatus      DeviceHealthStatus @default(UNKNOWN)
  isActive           Boolean          @default(true)
  isPrimary          Boolean          @default(false)
  dailySendLimit    Int              @default(1000)
  hourlySendLimit   Int              @default(100)
  dailySentCount    Int              @default(0)
  hourlySentCount   Int              @default(0)
  authSecretHash    String?
  lastAuthenticatedAt DateTime?
  lastTokenIssuedAt DateTime?
  deviceAuthVersion Int              @default(1)
  lastDispatchAt    DateTime?
  lastSeenAt         DateTime?
  lastHeartbeatAt    DateTime?
  lastKnownIp        String?
  metadata           Json?
  capabilities       Json?
  lastQuotaResetAt   DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  deletedAt          DateTime?

  organization       Organization     @relation("OrganizationDevices", fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy          User?           @relation("UserCreatedDevices", fields: [createdByUserId], references: [id], onDelete: SetNull)
  heartbeats         DeviceHeartbeat[] @relation("DeviceHeartbeats")
  outboundMessages   OutboundMessage[] @relation("DeviceOutboundMessages")

  @@index([organizationId])
  @@index([status])
  @@index([platform])
  @@index([lastHeartbeatAt])
  @@index([organizationId, isActive])
  @@index([organizationId, status])
}

model DeviceHeartbeat {
  id               String         @id @default(cuid())
  deviceId         String
  organizationId   String
  status           DeviceStatus
  batteryLevel    Int?
  signalStrength  Int?
  networkType     String?
  appVersion      String?
  ipAddress       String?
  payload         Json?
  createdAt       DateTime       @default(now())

  device          Device          @relation("DeviceHeartbeats", fields: [deviceId], references: [id], onDelete: Cascade)
  organization    Organization    @relation("OrganizationDeviceHeartbeats", fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([deviceId])
  @@index([organizationId])
  @@index([deviceId, createdAt(sort: Desc)])
}

model Contact {
  id                    String        @id @default(cuid())
  organizationId        String
  createdByUserId       String?
  firstName             String?
  lastName              String?
  fullName              String?
  phoneNumber           String
  normalizedPhoneNumber String
  email                 String?
  status                ContactStatus @default(ACTIVE)
  source                ContactSource @default(MANUAL)
  notes                 String?
  metadata              Json?
  lastContactedAt       DateTime?
  optedOutAt            DateTime?
  blockedAt             DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  deletedAt             DateTime?

  organization          Organization  @relation("OrganizationContacts", fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy             User?         @relation("UserCreatedContacts", fields: [createdByUserId], references: [id], onDelete: SetNull)
  listMemberships       ContactListMembership[] @relation("ContactListMembershipsByContact")
  customFieldValues     ContactCustomFieldValue[] @relation("ContactCustomFieldValuesByContact")
  campaignRecipients    CampaignRecipient[]       @relation("ContactCampaignRecipients")
  outboundMessages      OutboundMessage[]

  @@unique([organizationId, normalizedPhoneNumber])
  @@index([organizationId])
  @@index([status])
  @@index([createdAt])
}

model ContactList {
  id             String      @id @default(cuid())
  organizationId String
  createdByUserId String?
  name           String
  description    String?
  color          String?
  isArchived     Boolean     @default(false)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  deletedAt      DateTime?

  organization   Organization @relation("OrganizationContactLists", fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy      User?        @relation("UserCreatedContactLists", fields: [createdByUserId], references: [id], onDelete: SetNull)
  memberships    ContactListMembership[] @relation("ContactListMembershipsByList")

  @@unique([organizationId, name])
  @@index([organizationId])
}

model ContactListMembership {
  id            String      @id @default(cuid())
  organizationId String
  contactId     String
  contactListId String
  createdAt     DateTime    @default(now())

  organization  Organization @relation("OrganizationContactListMemberships", fields: [organizationId], references: [id], onDelete: Cascade)
  contact       Contact      @relation("ContactListMembershipsByContact", fields: [contactId], references: [id], onDelete: Cascade)
  contactList   ContactList  @relation("ContactListMembershipsByList", fields: [contactListId], references: [id], onDelete: Cascade)

  @@unique([contactId, contactListId])
  @@index([organizationId])
  @@index([contactListId])
}

model ContactCustomFieldValue {
  id            String                      @id @default(cuid())
  organizationId String
  contactId     String
  fieldKey      String
  fieldValue    String
  valueType     ContactCustomFieldValueType
  createdAt     DateTime                    @default(now())
  updatedAt     DateTime                    @updatedAt

  organization  Organization @relation("OrganizationContactCustomFieldValues", fields: [organizationId], references: [id], onDelete: Cascade)
  contact       Contact      @relation("ContactCustomFieldValuesByContact", fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([contactId, fieldKey])
  @@index([organizationId, fieldKey])
}

model Template {
  id             String              @id @default(cuid())
  organizationId String
  createdByUserId String?
  name           String
  description    String?
  body           String
  channelType    TemplateChannelType @default(SMS)
  isArchived     Boolean             @default(false)
  metadata       Json?
  lastUsedAt     DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  deletedAt      DateTime?

  organization   Organization        @relation("OrganizationTemplates", fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy      User?               @relation("UserCreatedTemplates", fields: [createdByUserId], references: [id], onDelete: SetNull)
  campaigns      Campaign[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

model Campaign {
  id               String         @id @default(cuid())
  organizationId   String
  createdByUserId String?
  name             String
  description      String?
  status           CampaignStatus @default(DRAFT)
  templateId       String?
  scheduledAt      DateTime?
  startedAt        DateTime?
  completedAt      DateTime?
  cancelledAt      DateTime?
  pausedAt         DateTime?
  failureReason    String?
  timezone         String?
  metadata         Json?
  /// Persisted targeting: `{ contactIds: string[], contactListIds: string[] }` for snapshot regeneration.
  target           Json?
  /// Template snapshot rendering: `strict` fails missing vars per recipient; `empty` substitutes blanks.
  missingVariableStrategy String @default("empty")
  recipientCount   Int            @default(0)
  readyCount       Int            @default(0)
  sentCount        Int            @default(0)
  deliveredCount   Int            @default(0)
  failedCount      Int            @default(0)
  skippedCount     Int            @default(0)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  deletedAt        DateTime?

  organization Organization         @relation("OrganizationCampaigns", fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User?                @relation("UserCreatedCampaigns", fields: [createdByUserId], references: [id], onDelete: SetNull)
  template     Template?            @relation(fields: [templateId], references: [id], onDelete: SetNull)
  recipients   CampaignRecipient[]
  outboundMessages OutboundMessage[] @relation("CampaignOutboundMessages")

  @@index([organizationId])
  @@index([status])
  @@index([scheduledAt])
  @@index([organizationId, status])
}

model CampaignRecipient {
  id                    String                      @id @default(cuid())
  organizationId        String
  campaignId            String
  contactId               String?
  sourceType            CampaignRecipientSourceType
  sourceRefId           String?
  normalizedPhoneNumber String
  resolvedName          String?
  mergeFields           Json?
  renderedBody          String?
  status                CampaignRecipientStatus     @default(PENDING)
  skipReason            String?
  scheduledAt           DateTime?
  queuedAt              DateTime?
  processedAt           DateTime?
  sentAt                DateTime?
  deliveredAt           DateTime?
  failedAt              DateTime?
  failureReason         String?
  createdAt             DateTime                    @default(now())
  updatedAt             DateTime                    @updatedAt

  organization Organization @relation("OrganizationCampaignRecipients", fields: [organizationId], references: [id], onDelete: Cascade)
  campaign     Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact      Contact?     @relation("ContactCampaignRecipients", fields: [contactId], references: [id], onDelete: SetNull)
  outboundMessages OutboundMessage[] @relation("CampaignRecipientOutboundMessages")

  @@index([campaignId])
  @@index([organizationId])
  @@index([status])
  @@index([normalizedPhoneNumber])
  @@index([campaignId, status])
}

model OutboundMessage {
  id                  String             @id @default(cuid())
  organizationId      String
  campaignId          String?
  campaignRecipientId String?
  deviceId            String?
  contactId           String?
  channelType         MessageChannelType @default(SMS)
  direction           MessageDirection   @default(OUTBOUND)
  normalizedPhoneNumber String
  renderedBody        String
  mediaUrl            String?
  status              MessageStatus      @default(PENDING)
  failureCode         String?
  failureReason       String?
  retryCount          Int                @default(0)
  maxRetries          Int                @default(3)
  nextRetryAt         DateTime?
  scheduledAt         DateTime?
  queuedAt            DateTime?
  dispatchingAt       DateTime?
  dispatchedAt        DateTime?
  sentAt              DateTime?
  deliveredAt         DateTime?
  failedAt            DateTime?
  cancelledAt         DateTime?
  claimedAt           DateTime?
  claimIdempotencyKey String?
  providerReference   String?
  lastStatusAt        DateTime?
  metadata            Json?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  organization        Organization       @relation("OrganizationOutboundMessages", fields: [organizationId], references: [id], onDelete: Cascade)
  campaign            Campaign?          @relation("CampaignOutboundMessages", fields: [campaignId], references: [id], onDelete: SetNull)
  campaignRecipient   CampaignRecipient? @relation("CampaignRecipientOutboundMessages", fields: [campaignRecipientId], references: [id], onDelete: SetNull)
  device              Device?            @relation("DeviceOutboundMessages", fields: [deviceId], references: [id], onDelete: SetNull)
  contact             Contact?           @relation(fields: [contactId], references: [id], onDelete: SetNull)
  statusEvents        MessageStatusEvent[] @relation("OutboundMessageStatusEvents")
  gatewayEventReceipts MessageGatewayEventReceipt[] @relation("OutboundMessageGatewayEventReceipts")

  @@index([organizationId])
  @@index([campaignId])
  @@index([campaignRecipientId])
  @@index([deviceId])
  @@index([status])
  @@index([scheduledAt])
  @@index([nextRetryAt])
  @@index([organizationId, status])
  @@index([campaignId, status])
}

model MessageStatusEvent {
  id                String        @id @default(cuid())
  organizationId    String
  outboundMessageId String
  fromStatus        MessageStatus?
  toStatus          MessageStatus
  reason            String?
  metadata          Json?
  createdAt         DateTime      @default(now())

  organization      Organization  @relation("OrganizationMessageStatusEvents", fields: [organizationId], references: [id], onDelete: Cascade)
  outboundMessage   OutboundMessage @relation("OutboundMessageStatusEvents", fields: [outboundMessageId], references: [id], onDelete: Cascade)

  @@index([outboundMessageId])
  @@index([organizationId])
  @@index([createdAt])
}

model MessageGatewayEventReceipt {
  id                String      @id @default(cuid())
  organizationId    String
  outboundMessageId String
  eventType         String
  idempotencyKey    String
  createdAt         DateTime    @default(now())

  organization      Organization @relation("OrganizationGatewayEventReceipts", fields: [organizationId], references: [id], onDelete: Cascade)
  outboundMessage   OutboundMessage @relation("OutboundMessageGatewayEventReceipts", fields: [outboundMessageId], references: [id], onDelete: Cascade)

  @@unique([outboundMessageId, eventType, idempotencyKey])
  @@index([organizationId])
  @@index([createdAt])
}

model AuditLog {
  id             String   @id @default(cuid())
  actorUserId    String?
  organizationId String?
  action         AuditAction
  entityType     String?
  entityId       String?
  metadata       Json?
  ipAddress      String?
  userAgent      String?
  requestId      String?
  createdAt      DateTime @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  actor        User?         @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([actorUserId, createdAt])
}

model BillingCustomer {
  id                 String          @id @default(cuid())
  organizationId     String
  provider           BillingProvider
  providerCustomerId String
  email              String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  organization       Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subscriptions      OrganizationSubscription[]

  @@unique([provider, providerCustomerId])
  @@unique([organizationId, provider])
}

model BillingPlan {
  id                String             @id @default(cuid())
  code              String             @unique
  name              String
  description       String?
  provider          BillingProvider
  providerProductId String?
  providerPriceId   String?
  interval          PlanInterval?
  isActive          Boolean            @default(true)
  sortOrder         Int                @default(0)
  metadata          Json?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  entitlements      BillingEntitlement[]
  subscriptions     OrganizationSubscription[]
}

model BillingEntitlement {
  id           String               @id @default(cuid())
  planId       String
  code         String
  valueType    EntitlementValueType
  booleanValue Boolean?
  numberValue  Int?
  stringValue  String?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  plan         BillingPlan          @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, code])
}

model OrganizationSubscription {
  id                     String             @id @default(cuid())
  organizationId         String
  billingCustomerId      String?
  billingPlanId          String?
  provider               BillingProvider
  providerSubscriptionId String?
  status                 SubscriptionStatus @default(INCOMPLETE)
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  cancelAtPeriodEnd      Boolean            @default(false)
  cancelledAt            DateTime?
  trialEndsAt            DateTime?
  lastWebhookAt          DateTime?
  metadata               Json?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  organization           Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  billingCustomer        BillingCustomer?   @relation(fields: [billingCustomerId], references: [id], onDelete: SetNull)
  billingPlan            BillingPlan?       @relation(fields: [billingPlanId], references: [id], onDelete: SetNull)

  @@unique([organizationId, provider])
  @@unique([provider, providerSubscriptionId])
  @@index([organizationId])
  @@index([status])
}

model UsageCounter {
  id             String       @id @default(cuid())
  organizationId String
  code           String
  periodKey      String       @default("")
  value          Int          @default(0)
  updatedAt      DateTime     @updatedAt
  createdAt      DateTime     @default(now())

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, code, periodKey])
}

model BillingEventLog {
  id              String          @id @default(cuid())
  organizationId  String?
  provider        BillingProvider
  eventType       String
  providerEventId String
  payload         Json
  processedAt     DateTime?
  createdAt       DateTime        @default(now())

  organization    Organization?   @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@unique([provider, providerEventId])
}
