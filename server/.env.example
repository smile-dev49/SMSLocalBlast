NODE_ENV=development
PORT=3000

# App URL (CORS / Office add-in origin in production)
PUBLIC_ORIGIN=http://localhost:3000

# Supabase — Dashboard → Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_YOUR_KEY_HERE

# Optional: server-only, never commit, never send to browser / Excel.
# Lets this API bypass RLS for trusted routes (recommended for backend queue/auth until you use user JWTs).
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Legacy names (still read by the server if you prefer):
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
# SUPABASE_ANON_KEY=
