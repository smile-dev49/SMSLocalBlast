{
  "name": "@sms-localblast/api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "prebuild": "pnpm -C ../.. exec prisma generate",
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "start:prod": "node dist/main.js",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
