NODE_ENV=development
PORT=3001
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# God View + revoke (set GOD_VIEW_SECRET for /god-view dashboard)
