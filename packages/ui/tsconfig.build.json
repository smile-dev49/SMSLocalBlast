{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "noEmit": false,
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "dist",
    "rootDir": "src"
  },
  "include": ["src/**/*.tsx", "src/**/*.ts"],
  "exclude": ["**/*.spec.tsx", "**/*.test.tsx"]
}
