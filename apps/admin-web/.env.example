# Set to `true` on non-Windows CI/Linux hosts when you need `.next/standalone` (Docker).
# NEXT_STANDALONE_OUTPUT=true

NEXT_PUBLIC_APP_URL=http://localhost:3001
NEXT_PUBLIC_APP_NAME=SMS LocalBlast Admin

# Browser-side API base (must include `/api/v1` — matches Nest global prefix + version).
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api/v1
