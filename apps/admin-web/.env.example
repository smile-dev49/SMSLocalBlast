# Set to `true` on non-Windows CI/Linux hosts when you need `.next/standalone` (Docker).
# NEXT_STANDALONE_OUTPUT=true

# Public URL of the admin app (used for auth callbacks when configured)
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Backend API base URL for browser-side calls (when introduced)
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000
