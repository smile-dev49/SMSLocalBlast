# Core
NODE_ENV=development
PORT=3000
API_PREFIX=api
APP_NAME=SMS LocalBlast API
APP_URL=http://localhost:3000

# HTTP hardening
BODY_LIMIT=1mb
TRUST_PROXY=false

# Comma-separated origins, or * for reflect-any (credentials disabled when *)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Data stores (Supabase Postgres connection string)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

# Redis (BullMQ + cache)
REDIS_URL=redis://127.0.0.1:6379

# JWT (min 16 chars; rotate in production)
JWT_ACCESS_SECRET=change-me-access-secret-16+
JWT_REFRESH_SECRET=change-me-refresh-secret-16+
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# Docs
SWAGGER_ENABLED=true

# Logging (pino)
LOG_LEVEL=info

# Queues
QUEUES_ENABLED=true
QUEUE_PREFIX=sms-localblast
MESSAGE_DISPATCH_WORKER_CONCURRENCY=10
MESSAGE_RETRY_WORKER_CONCURRENCY=2
MESSAGE_MAX_RETRIES_DEFAULT=3
MESSAGE_RETRY_BASE_DELAY_SECONDS=30
MESSAGE_RETRY_MAX_DELAY_SECONDS=900
MESSAGE_DISPATCH_STUCK_THRESHOLD_SECONDS=300
MESSAGE_CALLBACK_TIMEOUT_SECONDS=900
MESSAGE_RECOVERY_SWEEP_SECONDS=60
MESSAGE_RETRY_BATCH_SIZE=100
MESSAGE_DEAD_LETTER_THRESHOLD=5

# Stripe billing foundation
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_DEFAULT_CURRENCY=usd
STRIPE_SUCCESS_URL=http://localhost:3001/billing?checkout=success
STRIPE_CANCEL_URL=http://localhost:3001/billing?checkout=cancel
STRIPE_BILLING_PORTAL_RETURN_URL=http://localhost:3001/billing

# Device heartbeat health thresholds (seconds since last heartbeat)
DEVICE_ONLINE_THRESHOLD_SECONDS=120
DEVICE_WARNING_THRESHOLD_SECONDS=600
DEVICE_CRITICAL_THRESHOLD_SECONDS=1800
