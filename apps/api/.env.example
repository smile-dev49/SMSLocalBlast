# Core
NODE_ENV=development
PORT=3000
API_PREFIX=api
APP_NAME=SMS LocalBlast API
APP_URL=http://localhost:3000

# HTTP hardening
BODY_LIMIT=1mb
TRUST_PROXY=false

# Comma-separated origins, or * for reflect-any (credentials disabled when *)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Data stores (Supabase Postgres connection string)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

# Redis (BullMQ + cache)
REDIS_URL=redis://127.0.0.1:6379

# JWT (min 16 chars; rotate in production)
JWT_ACCESS_SECRET=change-me-access-secret-16+
JWT_REFRESH_SECRET=change-me-refresh-secret-16+
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# Docs
SWAGGER_ENABLED=true

# Logging (pino)
LOG_LEVEL=info

# Queues (set false for tests or when workers run elsewhere)
QUEUES_ENABLED=true
QUEUE_PREFIX=sms-localblast

# Device heartbeat health thresholds (seconds since last heartbeat)
DEVICE_ONLINE_THRESHOLD_SECONDS=120
DEVICE_WARNING_THRESHOLD_SECONDS=600
DEVICE_CRITICAL_THRESHOLD_SECONDS=1800
